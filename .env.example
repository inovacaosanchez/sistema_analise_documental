# Ambiente
APP_ENV=development
FLASK_ENV=development
APP_HOST=127.0.0.1
APP_PORT=5300
APP_PUBLIC_HOST=

# Seguranca de sessao/auth
APP_SECRET_KEY=trocar_por_valor_longo_e_unico
AUTH_SALT=trocar_por_salt_longo_e_unico
SESSION_COOKIE_SAMESITE=Lax
SESSION_LIFETIME_HOURS=12
ENABLE_SECURITY_HEADERS=1
ENABLE_CSRF=1
ENABLE_LOGIN_RATE_LIMIT=1

# OpenAI
OPENAI_API_KEY=<SECRET>
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=
OPENAI_MAX_TOKENS=4000
OPENAI_TEMPERATURE=0.3
OPENAI_TIMEOUT=60
OPENAI_RETRY_MAX_ATTEMPTS=4
OPENAI_RETRY_BASE_SECONDS=2
OPENAI_CALL_INTERVAL_SEC=3

# Rate limit de login
LOGIN_RATE_WINDOW_SEC=300
LOGIN_RATE_IP_MAX=20
LOGIN_RATE_USER_MAX=10

# Senhas temporarias
TEMP_PASSWORD_EXP_HOURS=24
ADMIN_INITIAL_PASSWORD=

# Supabase (opcional)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ENABLED=0

# Observacoes:
# 1) Nunca commitar arquivo .env com segredo real.
# 2) A chave OpenAI previamente hardcoded deve ser considerada comprometida e rotacionada.
